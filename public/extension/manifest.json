{
  "manifest_version": 3,
  "name": "FB Auto Remover",
  "version": "4.0",
  "description": "Remove automaticamente números do WhatsApp do Facebook",
  "permissions": ["activeTab", "scripting", "alarms", "tabs", "storage"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  },
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  }
}
